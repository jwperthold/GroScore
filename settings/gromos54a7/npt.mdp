integrator               = md
nsteps                   = 25000
dt                       = 0.004
mass-repartition-factor  = 3

nstxout                  = 20000
nstxout-compressed       = 20000
compressed-x-precision   = 1000
nstvout                  = 20000
nstfout                  = 20000
nstenergy                = 2000
nstlog                   = 2000
nstcalcenergy            = 2000

comm-mode                = linear
nstcomm                  = 1000

continuation             = yes
constraint_algorithm     = lincs
constraints              = all-bonds
lincs_iter               = 1
lincs_order              = 6

cutoff-scheme            = verlet
ns_type                  = grid
rlist                    = 1.4
rcoulomb                 = 1.4
rvdw                     = 1.4

vdwtype                  = cut-off
vdw-modifier             = none

coulombtype              = P3M-AD
coulomb-modifier         = none

tcoupl                   = V-rescale
tc-grps                  = Protein Non-Protein
tau_t                    = 0.1  0.1
ref_t                    = 310  310

pcoupl                   = Berendsen
pcoupltype               = isotropic
tau_p                    = 0.5
ref_p                    = 1.0
compressibility          = 4.5e-5
refcoord_scaling         = com

pbc                      = xyz

gen_vel                  = no
