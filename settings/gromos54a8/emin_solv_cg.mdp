define                   = -DPOSRES -DFLEXIBLE

integrator               = cg
emtol                    = 10.0
emstep                   = 0.01
nsteps                   = 5000

nstlist                  = 1
cutoff-scheme            = verlet
ns_type                  = grid
coulombtype              = reaction-field
epsilon-rf               = 61
rlist                    = 1.4
rcoulomb                 = 1.4
rvdw                     = 1.4
pbc                      = xyz
